{
  "name": "@spatiumai/worker",
  "version": "0.1.0",
  "private": true,
  "description": "SpatiumAI evaluation worker — BullMQ job processor",
  "scripts": {
    "dev": "tsx watch src/worker.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/worker.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@sentry/node": "^8.0.0",
    "@spatiumai/shared": "workspace:*",
    "bullmq": "^5.4.2",
    "drizzle-orm": "^0.30.10",
    "ioredis": "^5.3.2",
    "pg": "^8.11.5",
    "pino": "^9.1.0",
    "pino-pretty": "^11.0.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "rimraf": "^5.0.7",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
