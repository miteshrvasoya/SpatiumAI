{
  "name": "@spatiumai/api",
  "version": "0.1.0",
  "private": true,
  "description": "SpatiumAI main API service — Fastify + Drizzle + WebSocket",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "drizzle-kit migrate",
    "migrate:generate": "drizzle-kit generate",
    "migrate:studio": "drizzle-kit studio",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/websocket": "^10.0.1",
    "@sentry/node": "^8.0.0",
    "@spatiumai/shared": "workspace:*",
    "bullmq": "^5.4.2",
    "drizzle-orm": "^0.30.10",
    "fastify": "^4.27.0",
    "ioredis": "^5.3.2",
    "pg": "^8.11.5",
    "pino": "^9.1.0",
    "pino-pretty": "^11.0.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.21.4",
    "rimraf": "^5.0.7",
    "supertest": "^7.0.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
