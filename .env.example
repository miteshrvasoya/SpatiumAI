# ─────────────────────────────────────────────────────────────────────────────
# SpatiumAI — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore.
# In production, all variables are read from AWS Secrets Manager.
# ─────────────────────────────────────────────────────────────────────────────

# ── Service Config ────────────────────────────────────────────────────────────
NODE_ENV=development
# ENVIRONMENT is for Python services
ENVIRONMENT=development

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (matches docker-compose.yml)
DATABASE_URL=postgresql://spatiumai:spatiumai_dev_password@localhost:5432/spatiumai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT (generate a random 64-char string for dev) ───────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING_DO_NOT_USE_IN_PRODUCTION
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

# ── Error Tracking (Sentry) ───────────────────────────────────────────────────
# Get from: https://sentry.io → Project → Settings → Client Keys
SENTRY_DSN=

# ── AWS S3 (file uploads) ─────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_S3_BUCKET=spatiumai-dev-uploads
# Leave empty in local dev — S3 downloads are mocked
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Internal Service URLs ─────────────────────────────────────────────────────
# In Docker Compose, these use service names.
# In local dev without Docker, use localhost.
PARSER_SERVICE_URL=http://localhost:8001
AI_SERVICE_URL=http://localhost:8002

# ── AI / Claude API ───────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=5

# ── Parser Service ────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=100

# ── Stripe (Sprint 6) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_STUDIO_PRICE_ID=

# ── Email (Resend.com) ────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@spatiumai.com
